{
  "version": 2,
  "name": "stellarmarketpay",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_STELLAR_NETWORK": "testnet",
    "NEXT_PUBLIC_APP_URL": "https://stellarmarketpay.vercel.app",
    "NEXT_PUBLIC_API_URL": "https://stellarmarketpay.vercel.app/api"
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
